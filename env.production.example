# Copy to .env.production on the server and fill in values.
# Required for docker-compose.production.yml.

# From config/master.key (keep secret)
RAILS_MASTER_KEY=

# Strong random password for Postgres (used by web + postgres service)
URL_SHORTENER_DATABASE_PASSWORD=

# Strong random password for ClickHouse
CLICKHOUSE_PASSWORD=

# Public base URL for short links (e.g. http://YOUR_EC2_IP or https://go.example.com)
SHORT_URL_BASE=
