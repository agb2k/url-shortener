<h1 class="text-2xl font-bold text-gray-900 mb-6">Short link created</h1>

<% if notice %>
  <p class="mb-4 p-3 rounded bg-green-100 text-green-800 text-sm"><%= notice %></p>
<% end %>

<%= turbo_stream_from @short_link %>

<div class="rounded border border-gray-200 p-5 space-y-4 bg-white">
  <div>
    <span class="text-xs font-medium text-gray-500 uppercase tracking-wide">Short URL</span>
    <div class="mt-1 flex items-center gap-2">
      <%= link_to @presenter.display_url, @presenter.redirect_path,
            target: "_blank", rel: "noopener",
            class: "text-blue-600 hover:underline font-mono break-all" %>
      <button
        id="copy-btn"
        data-url="<%= @presenter.display_url %>"
        class="shrink-0 text-xs rounded border border-gray-300 px-2 py-1 text-gray-500 hover:bg-gray-100 focus:outline-none focus:ring-2 focus:ring-blue-500">
        Copy
      </button>
    </div>
  </div>

  <div>
    <span class="text-xs font-medium text-gray-500 uppercase tracking-wide">Original URL</span>
    <p class="mt-1 text-gray-700 break-all"><%= @presenter.display_original_url %></p>
  </div>

  <div>
    <span class="text-xs font-medium text-gray-500 uppercase tracking-wide">Title</span>
    <p class="mt-1 text-gray-700" id="short_link_<%= @presenter.id %>_title"><%= @presenter.title_or_placeholder %></p>
  </div>
</div>

<script>
  (function() {
    var btn = document.getElementById('copy-btn');
    btn.addEventListener('click', function() {
      navigator.clipboard.writeText(btn.dataset.url).then(function() {
        btn.textContent = 'Copied!';
        setTimeout(function() { btn.textContent = 'Copy'; }, 2000);
      });
    });
  })();
</script>
