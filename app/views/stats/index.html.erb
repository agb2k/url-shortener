<div class="max-w-3xl mx-auto px-4 sm:px-6 pb-12">
  <h1 class="text-2xl font-bold text-gray-900 mb-6">Usage report</h1>

  <p class="mb-6">
    <%= link_to "Back to URL Shortener", root_path, class: "text-blue-600 hover:underline" %>
  </p>

  <div class="rounded border border-gray-200 p-4 mb-6 bg-gray-50">
    <h2 class="text-lg font-semibold text-gray-800 mb-2">Total clicks</h2>
    <p class="text-2xl font-mono text-gray-900"><%= @total_clicks %></p>
  </div>

  <div class="rounded border border-gray-200 overflow-hidden mb-6">
    <h2 class="text-lg font-semibold text-gray-800 p-4 bg-gray-50 border-b border-gray-200">Clicks per short URL</h2>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Short URL</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Original URL</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Clicks</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Countries</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% if @per_link_stats.present? %>
          <% @per_link_stats.each do |row| %>
            <tr>
              <td class="px-4 py-2 text-sm">
                <%= link_to short_link_display_url(row[:short_link].short_code), short_link_redirect_path(row[:short_link].short_code), target: "_blank", rel: "noopener", class: "text-blue-600 hover:underline font-mono" %>
              </td>
              <td class="px-4 py-2 text-sm text-gray-600 max-w-xs truncate" title="<%= row[:short_link].original_url %>">
                <%= row[:short_link].original_url.sub(/\Ahttps?:\/\//, "") %>
              </td>
              <td class="px-4 py-2 text-sm font-mono text-gray-700"><%= row[:clicks] %></td>
              <td class="px-4 py-2 text-sm text-gray-600"><%= row[:countries].sort_by { |_, c| -c }.map { |country, count| "#{country} (#{count})" }.join(", ") %></td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="4" class="px-4 py-6 text-center text-gray-500">No visits yet.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <div class="rounded border border-gray-200 overflow-hidden">
    <h2 class="text-lg font-semibold text-gray-800 p-4 bg-gray-50 border-b border-gray-200">Top countries (all links)</h2>
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Country</th>
          <th class="px-4 py-2 text-left text-xs font-medium text-gray-500 uppercase">Clicks</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% if @top_countries.any? %>
          <% @top_countries.each do |country, count| %>
            <tr>
              <td class="px-4 py-2 text-sm text-gray-900"><%= country.presence || "unknown" %></td>
              <td class="px-4 py-2 text-sm font-mono text-gray-700"><%= count %></td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="2" class="px-4 py-6 text-center text-gray-500">No visits yet.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
